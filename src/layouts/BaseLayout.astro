---
import '@/styles/global.css';
import type { LocaleString } from '@/types/landing';

interface Props {
  title: string;
  description: LocaleString;
}

const { title, description } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="es" data-lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#faf7f3" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#2a2520" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description.es} />
    <meta name="description" lang="en" content={description.en} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mora Sampaio" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description.es} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description.es} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap"
    />
  </head>
  <body>
    <a href="#main" class="skip-link">
      <span class="es">Saltar al contenido</span><span class="en">Skip to content</span>
    </a>

    <slot name="progress" />
    <slot name="nav" />

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <slot name="footer" />
    <slot name="overlays" />
  </body>
</html>
