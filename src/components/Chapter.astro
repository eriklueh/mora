---
import type { Chapter } from '@types/sanity';

interface Props {
  chapter: Chapter;
  bodyHtml?: string;
}

const { chapter, bodyHtml } = Astro.props;
---

<article class="prose prose-neutral dark:prose-invert max-w-none">
  <header class="mb-8">
    <p class="text-sm uppercase tracking-widest text-[color:var(--color-muted)]">
      Capítulo {chapter.order}
    </p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight">{chapter.title}</h1>
    {chapter.summary && <p class="mt-3 text-lg text-[color:var(--color-muted)]">{chapter.summary}</p>}
  </header>
  {bodyHtml && <div set:html={bodyHtml} />}
  <slot />
</article>
