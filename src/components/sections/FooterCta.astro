---
import type { FooterCta } from '@/types/landing';
import SectionHeading from '@components/SectionHeading.astro';

interface Props {
  data: FooterCta;
}

const { data } = Astro.props;
---

<section id="empezar" class="footer-cta">
  <SectionHeading
    label={data.label}
    title={data.title}
    emphasis={data.titleEmphasis}
    subtitle={data.subtitle}
  />

  <a
    href={data.cta.href}
    class="btn-primary"
    style="font-size:0.92rem;padding:1rem 2.5rem;letter-spacing:0.08em;"
    target={data.cta.href.startsWith('http') ? '_blank' : undefined}
    rel={data.cta.href.startsWith('http') ? 'noopener noreferrer' : undefined}
  >
    <span class="es">{data.cta.label.es}</span><span class="en">{data.cta.label.en}</span>
  </a>

  <p class="footer-signoff">{data.signoff}</p>
</section>
