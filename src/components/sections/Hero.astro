---
import type { Hero } from '@/types/landing';

interface Props {
  data: Hero;
}

const { data } = Astro.props;
---

<section class="hero">
  <div class="hero-bg"></div>

  <div class="hero-left">
    <span class="hero-tag">
      <span class="es">{data.tag.es}</span><span class="en">{data.tag.en}</span>
    </span>

    <h1 class="hero-title">
      <span class="es">{data.title.es} <em>{data.titleEmphasis.es}</em></span>
      <span class="en">{data.title.en} <em>{data.titleEmphasis.en}</em></span>
    </h1>

    {data.subtitleLines.map((line) => (
      <>
        <p class="hero-sub es">{line.es}</p>
        <p class="hero-sub en">{line.en}</p>
      </>
    ))}

    <div class="hero-ctas">
      {data.ctas.map((cta) => (
        <a href={cta.href} class={cta.variant === 'outline' ? 'btn-outline' : 'btn-primary'}>
          <span class="es">{cta.label.es}</span><span class="en">{cta.label.en}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="hero-right">
    <div class="hero-photo-wrap">
      <div class="hero-photo-decor"></div>
      <div class="photo-placeholder">
        <div class="no-img">
          <div class="ph-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
          </div>
          <p class="es">{data.photoLabel.es}</p>
          <p class="en">{data.photoLabel.en}</p>
        </div>
      </div>
      <div class="hero-badge" aria-hidden="true">
        <div class="badge-num">
          {data.badge.value}
          <small><span class="es">{data.badge.valueSuffix.es}</span><span class="en">{data.badge.valueSuffix.en}</span></small>
        </div>
        <div class="badge-label es">{data.badge.label.es}</div>
        <div class="badge-label en">{data.badge.label.en}</div>
      </div>
    </div>
  </div>

  <a href="#conoceme" class="hero-scroll-hint" aria-label="Scroll">
    <span class="es">Descubrir</span><span class="en">Discover</span>
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</section>
