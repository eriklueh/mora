---
// SSR: we need the query string at request time to pull the Checkout Session
// and show the right download links to the buyer.
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import { landing } from '@/content/landing';
import { stripe } from '@/lib/stripe';

interface PurchasedItem {
  name: string;
  downloadUrl: string | null;
}

const sessionId = Astro.url.searchParams.get('session_id');
let items: PurchasedItem[] = [];
let customerEmail: string | null = null;
let paid = false;
let fetchError: string | null = null;

if (sessionId) {
  try {
    const session = await stripe.checkout.sessions.retrieve(sessionId, {
      expand: ['line_items.data.price.product'],
    });
    paid = session.payment_status === 'paid';
    customerEmail = session.customer_details?.email ?? null;

    if (paid && session.line_items) {
      items = session.line_items.data.map((li) => {
        const price = li.price;
        const product = price && typeof price.product !== 'string' && !price.product.deleted
          ? price.product
          : null;
        return {
          name: product?.name ?? li.description ?? 'Programa',
          downloadUrl: product?.metadata?.download_url ?? null,
        };
      });
    }
  } catch (err) {
    fetchError = err instanceof Error ? err.message : 'Unknown error';
    console.error('[gracias] failed to retrieve session', err);
  }
}

const description = {
  es: '¡Gracias por tu compra! Tu programa viene en camino.',
  en: 'Thank you for your purchase! Your program is on its way.',
};

const waHref = `https://wa.me/${landing.contact.whatsapp.replace(/\D/g, '')}`;

// Any item without a download_url is a deferred fulfilment (e.g. Mora reaches
// out separately); we show a contextual message instead of a broken link.
const hasDownloads = items.some((i) => i.downloadUrl);
---

<BaseLayout title="¡Gracias! — Mora Sampaio" description={description}>
  <section class="thanks">
    <div class="thanks-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 6L9 17l-5-5"/>
      </svg>
    </div>

    <p class="thanks-label">
      <span class="es">¡Listo!</span><span class="en">All set!</span>
    </p>

    <h1 class="thanks-title">
      <span class="es">Gracias por <em>entrenar conmigo.</em></span>
      <span class="en">Thanks for <em>training with me.</em></span>
    </h1>

    {paid && items.length > 0 && (
      <div class="thanks-downloads">
        <h2 class="downloads-title">
          <span class="es">Tus programas</span><span class="en">Your programs</span>
        </h2>
        <ul class="downloads-list">
          {items.map((item) => (
            <li class="download-item">
              <div class="download-meta">
                <div class="download-name">{item.name}</div>
                {customerEmail && (
                  <div class="download-email">
                    <span class="es">Copia por email: </span><span class="en">Email copy: </span>
                    {customerEmail}
                  </div>
                )}
              </div>
              {item.downloadUrl ? (
                <a class="btn-primary download-btn" href={item.downloadUrl} download>
                  <span class="es">Descargar PDF</span><span class="en">Download PDF</span>
                </a>
              ) : (
                <span class="download-pending">
                  <span class="es">Mora te lo envía en las próximas horas</span>
                  <span class="en">Mora will send it in the next few hours</span>
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}

    {sessionId && !paid && !fetchError && (
      <p class="thanks-notice">
        <span class="es">Tu pago todavía no se confirmó. Si ya completaste el checkout, refrescá en unos segundos.</span>
        <span class="en">Your payment is not confirmed yet. If you just completed checkout, refresh in a few seconds.</span>
      </p>
    )}

    {fetchError && (
      <p class="thanks-notice error">
        <span class="es">No pudimos verificar tu compra automáticamente. Escribime por WhatsApp y lo resolvemos.</span>
        <span class="en">We couldn&rsquo;t verify your purchase automatically. Message me on WhatsApp and we&rsquo;ll sort it out.</span>
      </p>
    )}

    <div class="thanks-cards">
      <div class="thanks-card">
        <div class="thanks-step">01</div>
        <h2>
          <span class="es">{hasDownloads ? 'Ya podés empezar' : 'Revisá tu email'}</span>
          <span class="en">{hasDownloads ? 'You can start now' : 'Check your email'}</span>
        </h2>
        <p>
          <span class="es">{hasDownloads
            ? 'Descargate el PDF de arriba y también te dejo una copia en tu email.'
            : 'Tu programa en PDF llega en los próximos minutos al mail de la compra. Si no lo ves, revisá spam o promociones.'}</span>
          <span class="en">{hasDownloads
            ? 'Download the PDF above — a copy is also on its way to your email.'
            : 'Your program PDF arrives in the next few minutes to the email you used at checkout. If it\u2019s not there, check spam or promotions.'}</span>
        </p>
      </div>

      <div class="thanks-card">
        <div class="thanks-step">02</div>
        <h2>
          <span class="es">¿Compraste el Challenge?</span>
          <span class="en">Bought the Challenge?</span>
        </h2>
        <p>
          <span class="es">Te escribo por WhatsApp en las próximas 24h para coordinar tu sesión 1 a 1.</span>
          <span class="en">I&rsquo;ll message you on WhatsApp within 24h to schedule your 1-on-1 session.</span>
        </p>
      </div>

      <div class="thanks-card">
        <div class="thanks-step">03</div>
        <h2>
          <span class="es">¿Alguna duda?</span>
          <span class="en">Any questions?</span>
        </h2>
        <p>
          <span class="es">Escribime cuando quieras y te respondo yo misma.</span>
          <span class="en">Message me anytime and I&rsquo;ll reply personally.</span>
        </p>
        <a class="btn-primary thanks-cta" href={waHref} target="_blank" rel="noopener noreferrer">
          <span class="es">Escribirme por WhatsApp</span>
          <span class="en">Message me on WhatsApp</span>
        </a>
      </div>
    </div>

    <a href="/" class="thanks-home">
      <span class="es">← Volver al inicio</span><span class="en">← Back home</span>
    </a>

    <p class="thanks-signoff">— Mora</p>
  </section>
</BaseLayout>

<style>
  .thanks {
    min-height: calc(100vh - 0px);
    padding: 8rem 1.5rem 5rem;
    max-width: 920px;
    margin: 0 auto;
    text-align: center;
  }

  .thanks-icon {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    background: var(--rose-light);
    color: var(--rose-dark);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.75rem;
    animation: thanksPop 0.55s cubic-bezier(0.22, 1.4, 0.42, 1) both;
  }
  .thanks-icon svg {
    width: 30px;
    height: 30px;
  }
  @keyframes thanksPop {
    from { transform: scale(0.4); opacity: 0; }
    to   { transform: scale(1); opacity: 1; }
  }

  .thanks-label {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rose);
    margin-bottom: 0.75rem;
  }

  .thanks-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.6vw, 3rem);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin-bottom: 2.5rem;
  }
  .thanks-title em {
    color: var(--rose);
    font-style: italic;
  }

  .thanks-downloads {
    background: #fff;
    border: 1px solid rgba(201, 82, 106, 0.18);
    border-radius: 18px;
    padding: 1.75rem;
    margin-bottom: 2.5rem;
    text-align: left;
    box-shadow: var(--shadow-md);
  }
  .downloads-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--charcoal);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(201, 82, 106, 0.12);
  }
  .downloads-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .download-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .download-meta {
    flex: 1;
    min-width: 200px;
  }
  .download-name {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--charcoal);
    margin-bottom: 0.25rem;
  }
  .download-email {
    font-size: 0.78rem;
    color: var(--muted);
  }
  .download-btn {
    padding: 0.65rem 1.25rem;
    font-size: 0.75rem;
    white-space: nowrap;
  }
  .download-pending {
    font-size: 0.82rem;
    color: var(--muted);
    font-style: italic;
  }

  .thanks-notice {
    background: var(--rose-pale);
    border: 1px solid rgba(201, 82, 106, 0.2);
    border-radius: 14px;
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    font-size: 0.88rem;
    color: var(--charcoal);
    line-height: 1.6;
  }
  .thanks-notice.error {
    background: #fdf0f1;
    border-color: #e8b4bc;
  }

  .thanks-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
    text-align: left;
  }

  .thanks-card {
    background: #fff;
    border: 1px solid rgba(201, 82, 106, 0.12);
    border-radius: 18px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    transition:
      transform var(--dur) var(--ease-out),
      box-shadow var(--dur) var(--ease-out),
      border-color var(--dur) var(--ease-out);
  }
  .thanks-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: rgba(201, 82, 106, 0.28);
  }

  .thanks-step {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--rose-light);
    line-height: 1;
    margin-bottom: 0.75rem;
  }
  .thanks-card h2 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--charcoal);
    margin-bottom: 0.55rem;
    line-height: 1.25;
  }
  .thanks-card p {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 1rem;
    flex: 1;
  }
  .thanks-cta {
    align-self: flex-start;
    padding: 0.6rem 1.25rem;
    font-size: 0.72rem;
  }

  .thanks-home {
    display: inline-block;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    transition: color var(--dur-fast), background var(--dur-fast);
  }
  .thanks-home:hover {
    color: var(--rose);
    background: rgba(201, 82, 106, 0.05);
  }

  .thanks-signoff {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-style: italic;
    color: var(--muted);
    margin-top: 2rem;
  }

  @media (max-width: 760px) {
    .thanks {
      padding: 6rem 1.25rem 4rem;
    }
    .thanks-cards {
      grid-template-columns: 1fr;
    }
    .download-item {
      flex-direction: column;
      align-items: stretch;
    }
    .download-btn {
      width: 100%;
      text-align: center;
    }
  }
</style>
