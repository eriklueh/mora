---
import BaseLayout from '@layouts/BaseLayout.astro';
import ChapterView from '@components/Chapter.astro';
import type { Chapter } from '@types/sanity';
// import { sanity } from '@lib/sanity';
// import { ALL_CHAPTER_SLUGS_QUERY, CHAPTER_BY_SLUG_QUERY } from '@lib/queries';

export async function getStaticPaths() {
  // TODO(sanity): fetch slugs from Sanity once content exists.
  // const slugs = await sanity.fetch<string[]>(ALL_CHAPTER_SLUGS_QUERY);
  // return slugs.map((slug) => ({ params: { slug } }));
  return [] as Array<{ params: { slug: string }; props: { chapter: Chapter } }>;
}

type Props = { chapter: Chapter };
const { chapter } = Astro.props as Props;
---

<BaseLayout title={chapter.title} description={chapter.summary}>
  <ChapterView chapter={chapter} />
</BaseLayout>
