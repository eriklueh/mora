---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import ScrollProgress from '@components/ScrollProgress.astro';
import BackToTop from '@components/BackToTop.astro';
import RevealOnScroll from '@components/RevealOnScroll.astro';
import MobileStickyCta from '@components/MobileStickyCta.astro';
import Footer from '@components/Footer.astro';
import Hero from '@components/sections/Hero.astro';
import About from '@components/sections/About.astro';
import Paradigm from '@components/sections/Paradigm.astro';
import Products from '@components/sections/Products.astro';
import Preview from '@components/sections/Preview.astro';
import Habits from '@components/sections/Habits.astro';
import Timeline from '@components/sections/Timeline.astro';
import FooterCta from '@components/sections/FooterCta.astro';
import { landing } from '@/content/landing';
---

<BaseLayout title={landing.meta.title} description={landing.meta.description}>
  <ScrollProgress slot="progress" />
  <Nav slot="nav" logo={landing.nav.logo} links={landing.nav.links} />

  <Hero data={landing.hero} />
  <About data={landing.about} />
  <Paradigm data={landing.paradigm} />
  <Products data={landing.products} />
  <Preview data={landing.preview} />
  <Habits data={landing.habits} />
  <Timeline data={landing.timeline} />
  <FooterCta data={landing.footerCta} />

  <Footer slot="footer" />

  <Fragment slot="overlays">
    <MobileStickyCta href="#rutinas" labelEs="Ver programas" labelEn="See programs" />
    <BackToTop />
    <RevealOnScroll />
  </Fragment>
</BaseLayout>
