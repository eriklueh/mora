# Stripe keys — rotate frequently, never commit .env.local.
# Get these from https://dashboard.stripe.com/apikeys (or /test/apikeys for test mode).
STRIPE_SECRET_KEY=sk_test_...
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Obtained when you create a webhook endpoint in Stripe (or via `stripe listen` in dev).
STRIPE_WEBHOOK_SECRET=whsec_...
